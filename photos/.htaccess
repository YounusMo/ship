# User-uploaded content must never be interpreted as code.
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule \.(php[0-9]?|phtml|phar|cgi|pl|py|sh|jsp|asp)$ - [F,L]
</IfModule>
<FilesMatch "\.(?i:php|php[0-9]|phtml|phar|cgi|pl|py|sh|jsp|asp|htaccess|htpasswd)$">
    Require all denied
</FilesMatch>
Options -ExecCGI -Indexes
RemoveHandler .php .phtml .phar .pl .py .cgi
AddType text/plain .php .phtml .phar
