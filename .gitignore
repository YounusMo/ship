# Heavy, regenerable, or sensitive paths excluded from the local baseline.
# This .gitignore exists for the local rollback repo only — not for sharing.

# Composer / npm artifacts (regenerable from lockfiles)
system/vendor/
system/node_modules/
system/public/build/

# Laravel runtime / cache / logs (regenerable, can contain request data)
system/storage/framework/cache/
system/storage/framework/sessions/
system/storage/framework/views/
system/storage/framework/testing/
system/storage/logs/*.log
system/bootstrap/cache/*.php
!system/bootstrap/cache/.gitignore
system/.phpunit.result.cache

# Database dumps — large + sensitive. Keep backups out of the source repo.
cron_jobs/backups/*.sql
cron_jobs/backups_zip/
backups_sub/
*.sql

# OS / editor junk
.DS_Store
__MACOSX/
*.swp
Thumbs.db

# Playwright MCP telemetry (per-run screenshots, snapshots, console logs)
.playwright-mcp/

# User-uploaded content directories — track structure not contents. The
# patterns are anchored to system/public/ where the photos actually live;
# the previous unanchored patterns matched nothing and let uploads leak
# into commits.
system/public/photos/sea/*/
system/public/photos/sky/*/
system/public/photos/teacher/*/
!system/public/photos/.htaccess
!system/public/photos/sea/.gitkeep
!system/public/photos/sky/.gitkeep
