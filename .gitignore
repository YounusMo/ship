# Heavy, regenerable, or sensitive paths excluded from the local baseline.
# This .gitignore exists for the local rollback repo only — not for sharing.

# Composer / npm artifacts (regenerable from lockfiles)
system/vendor/
system/node_modules/
system/public/build/

# Laravel runtime / cache / logs (regenerable, can contain request data)
system/storage/framework/cache/
system/storage/framework/sessions/
system/storage/framework/views/
system/storage/framework/testing/
system/storage/logs/*.log
system/bootstrap/cache/*.php
!system/bootstrap/cache/.gitignore
system/.phpunit.result.cache

# Database dumps — large + sensitive. Keep backups out of the source repo.
cron_jobs/backups/*.sql
cron_jobs/backups_zip/
backups_sub/
*.sql
# Exception: the schema baseline is a tracked artifact CI loads before
# migrate to provide a coherent starting point for tables created by
# pre-Laravel SQL dumps rather than by migrations.
!system/database/schema/baseline.sql

# OS / editor junk
.DS_Store
__MACOSX/
*.swp
Thumbs.db

# Playwright MCP telemetry (per-run screenshots, snapshots, console logs)
.playwright-mcp/

# Debug screenshots saved at the repo root during browser smoke tests.
# Real product screenshots live in system/resources/ or are committed
# deliberately — this rule only ignores repo-root saves.
/*.png

# Vite dev-server marker file. Created by `npm run dev` and removed
# on shutdown — never useful to commit.
system/public/hot

# Laravel storage symlink — created by `php artisan storage:link`,
# points at storage/app/public/. Recreated on every deploy.
system/public/storage

# Environment files — contain secrets. .env.example IS tracked (it's
# the template); .env and any per-environment variants are not.
# NOTE: previously-tracked system/.env stays in git HISTORY even after
# untracking; rotate APP_KEY and any DB / API credentials that appeared
# in past commits.
.env
.env.*
!.env.example
!*.env.example

# Authorized signature scan, uploaded via /settings → Authorized
# signature. Real signatures are forgeable if leaked, so the binary
# stays on the operator's host and never enters source control.
# (An earlier commit pushed a 390-byte "John Doe" placeholder — that
# stub is benign; only the real signature is sensitive.)
system/public/images/signature.png

# User-uploaded content directories — track structure not contents. The
# patterns are anchored to system/public/ where the photos actually live;
# the previous unanchored patterns matched nothing and let uploads leak
# into commits.
system/public/photos/sea/*/
system/public/photos/sky/*/
system/public/photos/teacher/*/
!system/public/photos/.htaccess
!system/public/photos/sea/.gitkeep
!system/public/photos/sky/.gitkeep
