APP_NAME="Ship Flow"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8002

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ship_system
DB_USERNAME=ship_user
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum token TTL override (minutes). Default 30 days (43200).
# SANCTUM_EXPIRATION_MINUTES=43200

# Carrier integration
# SHIPSGO_API_KEY=
# SHIPSGO_WEBHOOK_SECRET=

# Push notifications
# FCM_PROJECT_ID=
# FCM_CREDENTIALS_PATH=/etc/shipflow/fcm.json

# Error monitoring (Sentry). Leave DSN empty in local dev — sentry is a
# no-op until a DSN is configured. Set traces sample rate low (5–10%)
# in production to bound APM cost.
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=production

# Audit-log immutability. In production, set AUDIT_ARCHIVE_CONNECTION
# to 'audit_admin' after granting INSERT+SELECT (only) on audit_log to
# the main app user and creating a separate audit_admin DB user with
# DELETE rights. See config/audit.php for the SQL.
# AUDIT_ARCHIVE_CONNECTION=audit_admin
# AUDIT_ADMIN_HOST=
# AUDIT_ADMIN_USER=shipflow_audit_admin
# AUDIT_ADMIN_PASSWORD=
