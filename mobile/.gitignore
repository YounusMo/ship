# Flutter build artifacts + per-developer config
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
build/
.idea/
.vscode/
*.iml

# Generated code (build_runner)
**/*.g.dart
**/*.freezed.dart

# Flutter i18n codegen — produced by `flutter pub get` from lib/l10n/*.arb.
# We commit the ARBs (source of truth); the generated dart is per-checkout.
lib/l10n/app_localizations.dart
lib/l10n/app_localizations_*.dart

# Firebase / platform secrets — must be supplied per environment.
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
ios/firebase_app_id_file.json
android/app/key.properties
android/app/*.jks
android/app/*.keystore
ios/Runner.xcworkspace/xcuserdata/
ios/Runner.xcodeproj/xcuserdata/
ios/Runner.xcodeproj/project.xcworkspace/xcuserdata/

# macOS / Linux / Windows host projects — regenerated by `flutter create`.
# We track only lib/, pubspec.yaml, analysis_options.yaml in this repo.
android/
ios/
macos/
linux/
windows/
web/

# OS junk
.DS_Store
