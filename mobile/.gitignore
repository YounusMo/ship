# Flutter build artifacts + per-developer config
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
build/
.idea/
.vscode/
*.iml

# Generated code (build_runner)
**/*.g.dart
**/*.freezed.dart

# Flutter i18n codegen — produced by `flutter pub get` from lib/l10n/*.arb.
# We commit the ARBs (source of truth); the generated dart is per-checkout.
lib/l10n/app_localizations.dart
lib/l10n/app_localizations_*.dart

# Firebase / platform secrets — must be supplied per environment.
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
ios/firebase_app_id_file.json
android/app/key.properties
android/app/*.jks
android/app/*.keystore
ios/Runner.xcworkspace/xcuserdata/
ios/Runner.xcodeproj/xcuserdata/
ios/Runner.xcodeproj/project.xcworkspace/xcuserdata/

# Host platform projects:
#   ios/ + android/ ARE tracked — their per-platform .gitignore (auto-
#     generated by `flutter create`) already excludes Pods/, xcuserdata,
#     keystores, etc. Tracking them means Podfile post_install tweaks,
#     Info.plist permissions, signing config and Android manifest changes
#     persist instead of being reset every fresh clone.
#   macOS/Linux/Windows/Web targets stay ignored — this is a phone app.
macos/
linux/
windows/
web/

# OS junk
.DS_Store
